# ══════════════════════════════════════════════════════
#  LegitFlix Plugin - .gitignore
# ══════════════════════════════════════════════════════

# -- .NET Build Outputs --
LegitFlix.Plugin/bin/
LegitFlix.Plugin/obj/
LegitFlix.Plugin/publish/
LegitFlix.Plugin/*.zip
publish/

# -- Built Client Assets (regenerated by `npm run build`) --
LegitFlix.Plugin/Assets/Client/

# -- Generated Packaging Artifacts --
LegitFlix.Plugin/manifest_snippet.json

# -- Client Dependencies & Build --
legitflix-client/node_modules/
legitflix-client/dist/

# -- Environment & Local Config --
legitflix-client/.env
legitflix-client/.env.local
legitflix-client/.env.*.local
legitflix-client/local-dev-config.json

# -- Local Development Scripts --
run-dev.ps1
manage-plugin.ps1
LegitFlix.Plugin/package_plugin.ps1

# -- AI Config --
.agents/
.gemini/
.antigravityignore
*.antigravityignore

# -- OS Files & Logs --
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# -- IDE & Editor --
.vs/
.vscode/
.idea/
*.user
*.suo
*.userosscache
*.sln.docstates
*.sw?
*.ntvs*
*.njsproj
*.sln
